# ── Groq (PRIMARY — ~800 tokens/sec, 14 400 req/day free) ────────────────────
# Register at https://console.groq.com → API Keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Cerebras (FAST tier fallback — ~2000 tokens/sec free) ────────────────────
# Register at https://inference.cerebras.ai → API Keys
CEREBRAS_API_KEY=your-cerebras-api-key-here

# ── OpenRouter (aggregator — free models available) ───────────────────────────
# Register at https://openrouter.ai → Keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── NVIDIA NIM (free credits — Llama 3.3 70B) ────────────────────────────────
# Register at https://build.nvidia.com → Get API Key
NVIDIA_API_KEY=your-nvidia-nim-api-key-here

# ── Together AI (pay-per-token, very cheap — DeepSeek V3, Qwen 2.5 72B) ──────
# Register at https://api.together.xyz → API Keys
TOGETHER_API_KEY=your-together-api-key-here

# ── HuggingFace Inference API (free tier with rate limits) ───────────────────
# Register at https://huggingface.co/settings/tokens
HF_API_KEY=your-huggingface-token-here

# ── Ollama (local, no API key needed) ────────────────────────────────────────
# Install: https://ollama.ai — then: ollama pull qwen2.5:32b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=false   # Set to "true" ONLY if Ollama is running locally

# ── Service ───────────────────────────────────────────────────────────────────
AI_SERVICE_PORT=8000
